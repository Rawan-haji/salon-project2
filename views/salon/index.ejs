<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salon App</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-card bookings-card">
    <h1>My Bookings</h1>
    <div class="action-bar">
    <a href="/">Home</a>
    </div>
<a href="/services">Create New Booking</a>

    <% if (allBookings.length === 0) { %>
        <div class="empty-state">
        <p>No booking found</p>
        </div>
    <% } else { %>
        <div class="bookings-list">
        <ul>
            <% allBookings.forEach((item) => { %>
                <div class="service-card booking-item">
            <div class="service-info">
                <li>
                     <%= item.title %><br/>
                     <% console.log(item)%>
                    Services <%= item.services %><br/>

                    <a href="/bookings/<%= item._id %>">View Details</a>
                 

                </li>
                
   
            </div>
                </div>
                <br/>
            <% }) %>
        </ul>
        </div></div>

    <% } %>

</body>
</html>