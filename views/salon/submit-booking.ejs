<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>submit-booking</title>
</head>
<body>
<h1>Booking Details</h1>

  <form action="/bookings" method="POST">
    
<% services.forEach(service => { %>
  <input type="hidden" name="services" value="<%= service %>">
<% }) %>



         <h3>1. Location Details:</h3>
         <div>
         <label>Home Number: <input type="text" name="home" required /></label>
       </div>


        <div>
      <label>Road Number: <input type="text" name="road" required /></label>
       </div>
        <div>
      <label>Street: <input type="text" name="street" required /></label>
        </div>

    <h3>2. Date & Time:</h3>
    <div>
      <label>Date: <input type="date" name="date" required /></label>
    </div>
    <div>
      <label>Time: <input type="time" name="time" required /></label>
    </div>

    <br>
    <button type="submit">Submit Booking</button>
  </form>
</body>
</html>