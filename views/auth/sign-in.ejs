<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>
     <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-card">
    <h1>Sign In</h1>
    <form  class="sign-in-class"  action="/auth/sign-in" method="POST">
        <div class="input-group">
        <label for="username">Username</label>
        <input class="sign-in-class" type="text" name="username"/>
        </div>

        <div class="input-group">
        <label for="password">Password</label>
        <input class="sign-in-class" type="password" name="password"/>
        </div>
        <button   id="sign-in-button" type="submit">Sign In</button>
    </form>
    </div>
    
</body>
</html>